  <joint name="base_yaw_joint" type="revolute">
    <parent link="base_link"/>
    <child link="base_yaw_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="2.0" velocity="1.0"/>
  </joint>

  <joint name="shoulder_pitch_joint" type="revolute">
    <parent link="base_yaw_link"/>
    <child link="shoulder_pitch_link"/>
    <origin xyz="-0.00005 0.00174 0.10826" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="2.0" velocity="1.0"/>
  </joint>

  <joint name="upper_arm_roll_joint" type="revolute">
    <parent link="shoulder_pitch_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="-0.0137 0.0318 0.1319" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-1.5708" upper="1.5708" effort="2.0" velocity="1.0"/>
  </joint>

  <joint name="elbow_pitch_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0.0119 -0.0671 0.0227" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="2.0" velocity="1.0"/>
  </joint>

  <joint name="elbow_roll_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="elbow_roll_link"/>
    <origin xyz="-0.0078 -0.0004 0" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="2.0" velocity="1.0"/>
  </joint>

  <joint name="wrist_pitch_joint" type="revolute">
    <parent link="elbow_roll_link"/>
    <child link="wrist_pitch_link"/>
    <origin xyz="0.0037 -0.0595 0.0041" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="2.0" velocity="1.0"/>
  </joint>

